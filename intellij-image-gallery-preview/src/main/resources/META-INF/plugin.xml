<idea-plugin>
    <id>com.yourorg.imagegallerypreview</id>
    <name>Image Gallery Preview</name>
    <vendor email="dev@yourorg.local">YourOrg</vendor>
    <idea-version since-build="241"/>

    <description><![CDATA[
        在工具窗口中预览 Android、Flutter、iOS 资源文件，支持分组筛选、快速复制、MediaInfo 信息查看，以及重复资源检测。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="ImageGalleryPreview"
                anchor="right"
                factoryClass="com.yourorg.imagegallerypreview.ui.ImageGalleryToolWindowFactory"
                icon="AllIcons.FileTypes.Image"/>
        <postStartupActivity implementation="com.yourorg.imagegallerypreview.startup.GalleryStartupActivity"/>
    </extensions>

    <actions>
        <action id="ImageGalleryPreview.Refresh"
                class="com.yourorg.imagegallerypreview.actions.RefreshGalleryAction"
                text="Refresh Image Gallery Preview"
                description="Refresh scanned assets"/>
    </actions>
</idea-plugin>

